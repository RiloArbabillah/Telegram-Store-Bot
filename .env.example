# Telegram Bot Configuration
BOT_TOKEN=
ADMIN_TELEGRAM_ID=
ADMIN_TELEGRAM_USERNAME=
ADMIN_SESSION_SECRET=
ADMIN_COOKIE_SECURE=true

# Database Configuration
DATABASE_URL=postgresql+psycopg://tele_store_bot:change_me@postgres:5432/tele_store_bot
POSTGRES_DB=tele_store_bot
POSTGRES_USER=tele_store_bot
POSTGRES_PASSWORD=change_me

# Docker / Coolify Deployment
WEBHOOK_BASE_URL=https://bot.example.com
PORT=3000
APP_PORT=3000

# Crypto Payment Configuration
CRYPTO_BOT_API_KEY=

# Telegram Payments (Card) Configuration
TELEGRAM_PROVIDER_TOKEN=

# Business currency contract for this bot. All stored wallet/product/payment amounts are whole IDR.
# Non-IDR providers such as Telegram Card and CryptoBot stay disabled unless explicitly adapted.
PAYMENT_CURRENCY=IDR

# Mailbox OTP search keyword used by https://chongzhi.art/api/mailbox/fetch
MAILBOX_SEARCH_KEYWORD=openai
# Mailbox keyword used to find account deactivation notices
MAILBOX_DEACTIVATED_SEARCH_KEYWORD=deactivated

# DANA QRIS Configuration
DANA_API_MODE=disabled
DANA_BASE_URL=https://api.sandbox.dana.id
DANA_PARTNER_ID=
DANA_CHANNEL_ID=1
DANA_MERCHANT_ID=
DANA_STORE_ID=
DANA_SUB_MERCHANT_ID=
DANA_TERMINAL_ID=
DANA_PRIVATE_KEY_PATH=
DANA_PUBLIC_KEY_PATH=
DANA_CALLBACK_URL=
